# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# ── Clerk ──────────────────────────────────────────────────────────────────
# Found in Clerk dashboard → API Keys → Advanced → JWKS endpoint
CLERK_JWKS_URL=https://<your-clerk-subdomain>.clerk.accounts.dev/.well-known/jwks.json

# ── CORS (production only) ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave unset locally (defaults to *).
# Example: ALLOWED_ORIGINS=https://chat-lab2.vercel.app
ALLOWED_ORIGINS=
